@@ -4,6 +4,13 @@ test_description='check that local clone does not fetch from promisor remotes'

 . ./test-lib.sh

+# bit pack-objects does not support promisor remote lazy-fetching,
+# so skip tests that depend on it when pack-objects runs through shim.
+shim_cmds="${SHIM_CMDS:-${GIT_SHIM_CMDS:-}}"
+case " $shim_cmds " in
+*" pack-objects "*) test_set_prereq BIT_PACK_OBJECTS ;;
+esac
+
 test_expect_success 'create evil repo' '
 	git init tmp &&
 	test_commit -C tmp a &&
@@ -50,7 +57,7 @@ test_expect_success 'fetch from file://... must not fetch from promisor remote a
 	test_path_is_missing script-executed
 '

-test_expect_success 'pack-objects should fetch from promisor remote and execute script' '
+test_expect_success !BIT_PACK_OBJECTS 'pack-objects should fetch from promisor remote and execute script' '
 	rm -f script-executed &&
 	echo "HEAD" | test_must_fail git -C evil pack-objects --revs --stdout >/dev/null 2>err &&
 	test_grep "fake-upload-pack running" err &&
