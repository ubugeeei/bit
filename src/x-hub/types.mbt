  ns : String // e.g., "commits", "review", "tips"
}

///|
pub fn Note::new(
  commit_id : @bit.ObjectId,
  body : String,
  author : String,
  created_at : Int64,
  ns? : String = "commits",
) -> Note {
  { commit_id, body, author, created_at, ns }
}

///|
