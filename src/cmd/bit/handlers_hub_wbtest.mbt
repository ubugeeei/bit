///|
test "hub notify: select_notify_records filters notify-only records" {
  let canonical = @hub.HubRecord::new(
    "hub/pr/1/meta", "pr", "canonical", "node-a", 1L,
  )
  let proposal = @hub.HubRecord::new(
    "hub/proposal/pr/p1/meta", "pr-proposal", "proposal", "node-b", 2L,
  )
  let selected = select_notify_records([canonical, proposal])
  @test.assert_eq(selected.length(), 1)
  assert_true(selected.contains("hub/proposal/pr/p1/meta"))
}

///|
test "hub notify: collect_changed_notify_records detects new and updated" {
  let before : Map[String, @hub.HubRecord] = {}
  before["hub/proposal/pr/p1/meta"] = @hub.HubRecord::new(
    "hub/proposal/pr/p1/meta", "pr-proposal", "old", "node-a", 1L,
  )
  let after : Map[String, @hub.HubRecord] = {}
  after["hub/proposal/pr/p1/meta"] = @hub.HubRecord::new(
    "hub/proposal/pr/p1/meta", "pr-proposal", "new", "node-a", 2L,
  )
  after["hub/proposal/pr/p2/meta"] = @hub.HubRecord::new(
    "hub/proposal/pr/p2/meta", "pr-proposal", "created", "node-b", 3L,
  )
  let changed = collect_changed_notify_records(before, after)
  @test.assert_eq(changed.length(), 2)
  @test.assert_eq(changed[0].key, "hub/proposal/pr/p1/meta")
  @test.assert_eq(changed[1].key, "hub/proposal/pr/p2/meta")
}

///|
test "hub notify: format_hub_notify_message handles hub.pr.proposal" {
  let proposal = @hub.PullRequest::new(
    "p-1",
    "External Proposal",
    "Body",
    "refs/heads/feature",
    @bitcore.ObjectId::zero(),
    "refs/heads/main",
    @bitcore.ObjectId::zero(),
    "peer-user",
    10L,
    10L,
    @hub.PrState::Open,
    [],
  )
  let record = @hub.HubRecord::new(
    @hub.pr_proposal_meta_key("p-1"),
    "pr-proposal",
    proposal.serialize(),
    "peer-node",
    10L,
  )
  let message = format_hub_notify_message("hub.pr.proposal", record)
  assert_true(message.contains("hub.pr.proposal"))
  assert_true(message.contains("#p-1"))
  assert_true(message.contains("External Proposal"))
  @test.assert_eq(
    format_hub_notify_message("hub.other", record),
    "[hub.notify] hub.other key=hub/proposal/pr/p-1/meta",
  )
}

///|
test "hub format: format_work_item_summary includes kind and state" {
  let item = @hub.WorkItem::new(
    "w1",
    "Unified title",
    "body",
    "alice",
    1L,
    2L,
    @hub.WorkItemState::Open,
  )
  let out = format_work_item_summary(item)
  assert_true(out.contains("#w1"))
  assert_true(out.contains("[issue/open]"))
  assert_true(out.contains("Unified title"))
}

///|
test "hub format: format_issue_summary shows sub counts and parent context" {
  let parent = @hub.Issue::new(
    "i-parent",
    "Parent issue",
    "body",
    "alice",
    1L,
    1L,
    @hub.IssueState::Open,
  )
  let child = @hub.Issue::new(
    "i-child",
    "Child issue",
    "body",
    "alice",
    2L,
    2L,
    @hub.IssueState::Open,
    parent_id=Some("i-parent"),
  )
  let parent_out = format_issue_summary(parent, child_count=2)
  assert_true(parent_out.contains("#i-parent"))
  assert_true(parent_out.contains("(sub: 2)"))
  let child_out = format_issue_summary(child, show_parent=true)
  assert_true(child_out.contains("#i-child"))
  assert_true(child_out.contains("(parent: i-parent)"))
  let nested_out = format_issue_summary(child, child_count=1, show_parent=true)
  assert_true(nested_out.contains("sub: 1"))
  assert_true(nested_out.contains("parent: i-parent"))
}

///|
test "hub issue list: collect_issue_list_lines shows top-level counts and tree" {
  let parent = @hub.Issue::new(
    "i-parent",
    "Parent issue",
    "body",
    "alice",
    1L,
    1L,
    @hub.IssueState::Open,
  )
  let child = @hub.Issue::new(
    "i-child",
    "Child issue",
    "body",
    "alice",
    2L,
    2L,
    @hub.IssueState::Open,
    parent_id=Some("i-parent"),
  )
  let grandchild = @hub.Issue::new(
    "i-grandchild",
    "Grandchild issue",
    "body",
    "alice",
    3L,
    3L,
    @hub.IssueState::Open,
    parent_id=Some("i-child"),
  )
  let sibling = @hub.Issue::new(
    "i-sibling",
    "Sibling issue",
    "body",
    "alice",
    4L,
    4L,
    @hub.IssueState::Open,
  )
  let issues = [parent, child, grandchild, sibling]

  let top_level = collect_issue_list_lines(issues, false, false, None)
  @test.assert_eq(top_level.length(), 2)
  assert_true(top_level[0].contains("#i-parent"))
  assert_true(top_level[0].contains("(sub: 1)"))
  assert_true(top_level[1].contains("#i-sibling"))

  let flat = collect_issue_list_lines(issues, true, false, None)
  @test.assert_eq(flat.length(), 4)
  assert_true(flat[1].contains("parent: i-parent"))
  assert_true(flat[1].contains("sub: 1"))
  assert_true(flat[2].contains("parent: i-child"))

  let tree = collect_issue_list_lines(issues, false, true, None)
  @test.assert_eq(tree.length(), 4)
  @test.assert_eq(tree[0], "#i-parent [open] Parent issue (sub: 1)")
  @test.assert_eq(tree[1], "  #i-child [open] Child issue (sub: 1)")
  @test.assert_eq(tree[2], "    #i-grandchild [open] Grandchild issue")
  @test.assert_eq(tree[3], "#i-sibling [open] Sibling issue")

  let child_only = collect_issue_list_lines(
    issues,
    false,
    true,
    Some("i-parent"),
  )
  @test.assert_eq(child_only.length(), 2)
  @test.assert_eq(child_only[0], "#i-child [open] Child issue (sub: 1)")
  @test.assert_eq(child_only[1], "  #i-grandchild [open] Grandchild issue")
}

///|
test "hub init: parse approval accepts only yes-like answers" {
  assert_true(parse_hub_init_approval("y"))
  assert_true(parse_hub_init_approval(" Yes \n"))
  assert_false(parse_hub_init_approval(""))
  assert_false(parse_hub_init_approval("n"))
  assert_false(parse_hub_init_approval("ok"))
}

///|
test "hub init: parse prompt override handles force on off and invalid" {
  @test.assert_eq(parse_hub_init_prompt_override("1"), Some(true))
  @test.assert_eq(parse_hub_init_prompt_override("yes"), Some(true))
  @test.assert_eq(parse_hub_init_prompt_override("0"), Some(false))
  @test.assert_eq(parse_hub_init_prompt_override("No"), Some(false))
  @test.assert_eq(parse_hub_init_prompt_override("maybe"), None)
}

///|
test "hub init: origin sync plan is empty without origin remote" {
  let config_text =
    #|[remote "upstream"]
    #|  url = https://example.com/upstream.git
    #|  fetch = +refs/heads/*:refs/remotes/upstream/*
  let plan = compute_hub_origin_sync_plan(config_text)
  assert_false(plan.has_origin)
  assert_false(plan.add_fetch_notes)
  assert_false(plan.add_push_notes)
  assert_false(plan.add_default_push_refspec)
}

///|
test "hub init: origin sync plan adds notes fetch and default push when origin has no push config" {
  let config_text =
    #|[remote "origin"]
    #|  url = https://example.com/origin.git
    #|  fetch = +refs/heads/*:refs/remotes/origin/*
  let plan = compute_hub_origin_sync_plan(config_text)
  assert_true(plan.has_origin)
  assert_true(plan.add_fetch_notes)
  assert_true(plan.add_push_notes)
  assert_true(plan.add_default_push_refspec)
}

///|
test "hub init: origin sync plan only adds notes push when origin already has push refspecs" {
  let config_text =
    #|[remote "origin"]
    #|  url = https://example.com/origin.git
    #|  fetch = +refs/heads/*:refs/remotes/origin/*
    #|  push = HEAD:refs/heads/main
  let plan = compute_hub_origin_sync_plan(config_text)
  assert_true(plan.has_origin)
  assert_true(plan.add_fetch_notes)
  assert_true(plan.add_push_notes)
  assert_false(plan.add_default_push_refspec)
}

///|
test "hub init: origin sync plan is empty when notes sync is already configured" {
  let config_text =
    #|[remote "origin"]
    #|  url = https://example.com/origin.git
    #|  fetch = +refs/heads/*:refs/remotes/origin/*
    #|  fetch = +refs/notes/bit-hub:refs/notes/bit-hub
    #|  push = HEAD:refs/heads/main
    #|  push = refs/notes/bit-hub:refs/notes/bit-hub
  let plan = compute_hub_origin_sync_plan(config_text)
  assert_true(plan.has_origin)
  assert_false(plan.add_fetch_notes)
  assert_false(plan.add_push_notes)
  assert_false(plan.add_default_push_refspec)
}
